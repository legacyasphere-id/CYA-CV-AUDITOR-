# Supabase
VITE_SUPABASE_URL=https://tikyxivcaqidpwftssrf.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Edge Functions (set in Supabase dashboard → Project Settings → Edge Functions → Secrets)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Provider — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
# Default model. Swap without changing any code.
# Options tested: openai/gpt-4.1-mini, openai/gpt-4o-mini, qwen/qwen-2.5-72b-instruct, deepseek/deepseek-chat
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Payment — Midtrans (set SERVER_KEY in Supabase dashboard → Edge Functions → Secrets)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_IS_PRODUCTION=false
# Client key is public — hardcoded in index.html (Mid-client-H6gRXCoXcDUXHTQg)

# App
APP_URL=https://your-vercel-domain.vercel.app
